module Anthropic
  module Helpers
    module Vertex
      class Client < Anthropic::Client
        DEFAULT_VERSION: String

        attr_reader region: String

        attr_reader project_id: String

        attr_reader messages: Anthropic::Resources::Messages

        attr_reader beta: Anthropic::Resources::Beta

        private def build_request: (
          Anthropic::Internal::Transport::BaseClient::request_components req,
          Anthropic::request_options opts
        ) -> Anthropic::Internal::Transport::BaseClient::request_input

        private def provider_middleware: -> Anthropic::Middleware::entry

        private def adapt_request: (
          Anthropic::APIRequest req
        ) -> Anthropic::APIRequest

        private def apply_google_auth: (
          Anthropic::APIRequest req
        ) -> Anthropic::APIRequest

        private def rewrite_path: (
          URI::Generic url,
          Regexp pattern,
          String replacement
        ) -> URI::Generic

        def initialize: (
          region: String?,
          project_id: String?,
          base_url: String?,
          max_retries: Integer,
          timeout: Float,
          initial_retry_delay: Float,
          max_retry_delay: Float,
          middleware: Anthropic::Middleware::entry_or_array?
        ) -> void
      end
    end
  end
end
